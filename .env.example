# PostgreSQL (ajuste usuário, senha, host, porta e nome do banco)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/folha_wizard?schema=public"
# Dev com Docker (porta 5433): docker compose -f docker-compose.postgres.yml up -d
# DATABASE_URL="postgresql://postgres:postgres@localhost:5433/folha_wizard?schema=public"
JWT_SECRET="troque-em-producao-use-string-longa-e-aleatoria"
JWT_EXPIRES_IN="7d"
PORT=3001
STORAGE_PATH="./storage"
